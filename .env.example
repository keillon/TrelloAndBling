PORT=3333

# Bling
BLING_API_BASE_URL=https://api.bling.com.br/Api/v3
BLING_ACCESS_TOKEN=your_bling_access_token
BLING_CLIENT_ID=your_bling_client_id
BLING_CLIENT_SECRET=your_bling_client_secret
BLING_REFRESH_TOKEN=your_bling_refresh_token
BLING_ALLOWED_STATUS=
BLING_MIN_ORDER_DATE=
BLING_SYNC_LOOKBACK_DAYS=7
BLING_MIN_INTERVAL_MS=350

# Trello
TRELLO_API_BASE_URL=https://api.trello.com/1
TRELLO_KEY=your_trello_key
TRELLO_TOKEN=your_trello_token
TRELLO_LIST_ID=your_trello_list_id
TRELLO_MIN_INTERVAL_MS=120

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Realtime (socket)
SOCKET_CORS_ORIGIN=http://localhost:5173

# Sync
SYNC_CRON=*/5 * * * * *
